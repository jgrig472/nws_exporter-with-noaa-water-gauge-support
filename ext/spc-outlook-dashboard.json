      "panel-4": {
        "kind": "Panel",
        "spec": {
          "id": 4,
          "title": "Day 1 Risk Map",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "text",
            "version": "13.0.2",
            "spec": {
              "options": {
                "mode": "html",
                "content": "<div id=\"mp-d1\" style=\"position:relative;width:100%;height:100%;background:#0d1b2a;overflow:hidden;font-family:'Helvetica Neue',Arial,sans-serif\">\n  <div id=\"mp-d1-status\" style=\"position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);color:#6a8aaa;font-size:13px\">Loading map…</div>\n  <canvas id=\"mp-d1-canvas\" style=\"display:block;position:absolute;top:0;left:0\"></canvas>\n  <div id=\"mp-d1-legend\" style=\"position:absolute;bottom:10px;right:10px;background:rgba(10,20,35,0.88);padding:8px 12px;border-radius:6px;font-size:11px;color:#ccc;border:1px solid rgba(255,255,255,0.12)\"></div>\n  <div style=\"position:absolute;top:8px;left:10px;color:#ccc;font-size:11px;font-weight:700;letter-spacing:0.5px;text-shadow:0 1px 3px rgba(0,0,0,0.9)\">DAY 1 CATEGORICAL RISK</div>\n</div>\n<script>\n(function() {\n  var DAY=1, P='mp-d'+DAY;\n  var el=document.getElementById(P);\n  var cv=document.getElementById(P+'-canvas');\n  var st=document.getElementById(P+'-status');\n  var lg=document.getElementById(P+'-legend');\n\n  function init() {\n    var W=el.offsetWidth, H=el.offsetHeight;\n    if (!W||!H) { setTimeout(init,100); return; }\n    cv.width=W; cv.height=H;\n    draw(W,H);\n  }\n  init();\n\n  function draw(W,H) {\n    var ctx=cv.getContext('2d');\n    var LN0=-127,LN1=-65,LT0=22,LT1=52;\n    function proj(ln,lt) { return [(ln-LN0)/(LN1-LN0)*W,(LT1-lt)/(LT1-LT0)*H]; }\n\n    function drawRings(rr) {\n      rr.forEach(function(ring) {\n        var s=false;\n        for (var i=0;i<ring.length;i++) {\n          var pt=ring[i];\n          if (pt[0]<-135||pt[0]>-60||pt[1]<18||pt[1]>56) continue;\n          var p=proj(pt[0],pt[1]);\n          if (!s){ctx.moveTo(p[0],p[1]);s=true;}else ctx.lineTo(p[0],p[1]);\n        }\n        if (s) ctx.closePath();\n      });\n    }\n\n    function drawGeom(g) {\n      if (!g) return;\n      ctx.beginPath();\n      if (g.type==='Polygon') drawRings(g.coordinates);\n      else if (g.type==='MultiPolygon') g.coordinates.forEach(function(p){drawRings(p);});\n    }\n\n    function fillFeat(f,fill,stroke,lw) {\n      drawGeom(f.geometry);\n      if (fill){ctx.fillStyle=fill;ctx.fill('evenodd');}\n      if (stroke){ctx.strokeStyle=stroke;ctx.lineWidth=lw||1;ctx.stroke();}\n    }\n\n    ctx.fillStyle='#0d1b2a'; ctx.fillRect(0,0,W,H);\n\n    Promise.all([\n      fetch('https://raw.githubusercontent.com/PublicaMundi/MappingAPI/master/data/geojson/us-states.json').then(function(r){return r.json();}).catch(function(){return null;}),\n      fetch('https://www.spc.noaa.gov/products/outlook/day1otlk_cat.nolyr.geojson?_='+Math.floor(Date.now()/300000)).then(function(r){return r.json();})\n    ]).then(function(res) {\n      var states=res[0], spc=res[1];\n      st.style.display='none';\n\n      // State fills (dark forest green)\n      if (states) states.features.forEach(function(f){fillFeat(f,'#182c20',null,0);});\n\n      // SPC risk areas — draw lowest risk first so higher risk paints on top\n      ctx.globalAlpha=0.7;\n      spc.features.slice().reverse().forEach(function(f) {\n        var p=f.properties; fillFeat(f,p.fill,p.stroke,2.5);\n      });\n      ctx.globalAlpha=1;\n\n      // State borders on top of risk areas\n      if (states) states.features.forEach(function(f) {\n        drawGeom(f.geometry); ctx.strokeStyle='#3d5a40'; ctx.lineWidth=0.8; ctx.stroke();\n      });\n\n      // Legend\n      var h='<div style=\"font-weight:700;margin-bottom:5px;color:#fff;font-size:10px;letter-spacing:0.5px\">RISK AREAS</div>';\n      if (!spc.features.length) {\n        h+='<div style=\"color:#6aaa6a;font-size:10px\">No severe weather areas</div>';\n      } else {\n        spc.features.forEach(function(f) {\n          var p=f.properties;\n          h+='<div style=\"display:flex;align-items:center;gap:6px;margin:2px 0\">';\n          h+='<div style=\"width:14px;height:10px;background:'+p.fill+';border:1.5px solid '+p.stroke+';border-radius:2px;flex-shrink:0\"></div>';\n          h+='<span style=\"font-size:10px;color:#ddd\"><b style=\"color:#fff\">'+p.LABEL+'</b> — '+p.LABEL2+'</span></div>';\n        });\n      }\n      lg.innerHTML=h;\n\n    }).catch(function(e){st.textContent='Map error: '+e.message;});\n  }\n})();\n</script>",
