    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Day 1 Convective Outlook",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "text",
            "version": "13.0.2",
            "spec": {
              "options": {
                "mode": "html",
                "content": "<div id=\"d1-wrap\" style=\"height:100%;overflow-y:auto;padding:10px;box-sizing:border-box;font-family:'Helvetica Neue',Arial,sans-serif\">\n  <div id=\"d1-loading\" style=\"color:#aaa;padding:20px;text-align:center\">Loading Day 1 outlook\u2026</div>\n</div>\n<script>\n(function() {\n  var wrap = document.getElementById('d1-wrap');\n\n  var RISKS = [\n    { key: 'HIGH RISK',            label: 'HIGH',      bg: '#FF00FF', fg: '#fff' },\n    { key: 'MODERATE RISK',        label: 'MODERATE',  bg: '#CC0000', fg: '#fff' },\n    { key: 'ENHANCED RISK',        label: 'ENHANCED',  bg: '#FF8C00', fg: '#fff' },\n    { key: 'SLIGHT RISK',          label: 'SLIGHT',    bg: '#DDAA00', fg: '#000' },\n    { key: 'MARGINAL RISK',        label: 'MARGINAL',  bg: '#006400', fg: '#fff' },\n    { key: 'GENERAL THUNDERSTORMS',label: 'GENERAL THUNDERSTORMS', bg: '#55BB55', fg: '#fff' },\n    { key: 'NO SEVERE',            label: 'NO SEVERE WEATHER',     bg: '#2D6E2D', fg: '#fff' },\n  ];\n\n  function extractBlock(text, header) {\n    var idx = text.indexOf(header);\n    if (idx < 0) return '';\n    var start = text.indexOf('\\n', idx) + 1;\n    var end = text.indexOf('\\n...', start);\n    if (end < 0) end = text.indexOf('\\n&&', start);\n    if (end < 0) end = text.length;\n    return text.slice(start, end).trim();\n  }\n\n  function render(text) {\n    var upper = text.toUpperCase();\n\n    // Determine risk level\n    var risk = { label: 'GENERAL THUNDERSTORMS', bg: '#55BB55', fg: '#fff' };\n    for (var i = 0; i < RISKS.length; i++) {\n      if (upper.indexOf(RISKS[i].key) >= 0) { risk = RISKS[i]; break; }\n    }\n\n    // Extract header block (lines before first blank line after Valid)\n    var validMatch = text.match(/Valid\\s+\\S+\\s*-\\s*\\S+/);\n    var validLine = validMatch ? validMatch[0] : '';\n\n    // Extract headline (the ...THERE IS... line)\n    var headlineMatch = text.match(/\\.\\.\\.([^\\n]+)\\.\\.\\.\\s*\\n/);\n    var headline = headlineMatch ? headlineMatch[1] : '';\n\n    // Extract issuance time line\n    var timeMatch = text.match(/\\d{3,4} [AP]M CDT[^\\n]*/);\n    var timeLine = timeMatch ? timeMatch[0] : '';\n\n    var summary = extractBlock(text, '...SUMMARY...');\n\n    // Build HTML\n    var html = '';\n\n    // Risk banner\n    html += '<div style=\"background:' + risk.bg + ';color:' + risk.fg + ';padding:8px 16px;border-radius:6px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center\">';\n    html += '<span style=\"font-size:18px;font-weight:700;letter-spacing:1px\">DAY 1 \u2014 ' + risk.label + '</span>';\n    html += '<a href=\"https://www.spc.noaa.gov/products/outlook/day1otlk.html\" target=\"_blank\" style=\"color:' + risk.fg + ';font-size:11px;opacity:0.85;text-decoration:none\">View on SPC \u2197</a>';\n    html += '</div>';\n\n    // Valid + issued\n    if (validLine || timeLine) {\n      html += '<div style=\"font-size:11px;color:#aaa;margin-bottom:8px\">';\n      if (timeLine) html += '<span style=\"margin-right:16px\">\ud83d\uddd3 Issued: ' + timeLine + '</span>';\n      if (validLine) html += '<span>' + validLine + '</span>';\n      html += '</div>';\n    }\n\n    // Headline\n    if (headline) {\n      html += '<div style=\"font-size:13px;font-weight:600;margin-bottom:10px;padding:8px 10px;border-left:3px solid ' + risk.bg + ';background:rgba(255,255,255,0.05)\">';\n      html += headline;\n      html += '</div>';\n    }\n\n    // Summary\n    if (summary) {\n      html += '<div style=\"margin-bottom:12px\">';\n      html += '<div style=\"font-size:11px;font-weight:700;letter-spacing:1px;color:#aaa;margin-bottom:4px\">SUMMARY</div>';\n      html += '<div style=\"font-size:13px;line-height:1.6\">' + summary.replace(/\\n/g, '<br>') + '</div>';\n      html += '</div>';\n    }\n\n    // Full text (collapsible)\n    html += '<details style=\"margin-top:8px\">';\n    html += '<summary style=\"cursor:pointer;font-size:11px;font-weight:700;letter-spacing:1px;color:#aaa;margin-bottom:6px\">FULL DISCUSSION</summary>';\n    html += '<pre style=\"white-space:pre-wrap;font-size:11px;line-height:1.5;color:#ccc;margin:0;padding:8px;background:rgba(0,0,0,0.2);border-radius:4px;overflow-x:auto\">' + text.replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</pre>';\n    html += '</details>';\n\n    wrap.innerHTML = html;\n  }\n\n  fetch('https://www.spc.noaa.gov/products/outlook/day1otlk.txt' + '?_=' + Math.floor(Date.now() / 300000))\n    .then(function(r) { return r.text(); })\n    .then(render)\n    .catch(function(e) {\n      wrap.innerHTML = '<div style=\"color:#f88;padding:20px\">Failed to load Day 1 outlook: ' + e + '<br><a href=\"https://www.spc.noaa.gov/products/outlook/day1otlk.html\" target=\"_blank\" style=\"color:#6bf\">Open on SPC</a></div>';\n    });\n})();\n</script>",
