x;color:#aaa;margin-bottom:6px\">FULL DISCUSSION</summary>';\n    html += '<pre style=\"white-space:pre-wrap;font-size:11px;line-height:1.5;color:#ccc;margin:0;padding:8px;background:rgba(0,0,0,0.2);border-radius:4px;overflow-x:auto\">' + text.replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</pre>';\n    html += '</details>';\n\n    wrap.innerHTML = html;\n  }\n\n  fetch('https://www.spc.noaa.gov/products/outlook/day2otlk.txt' + '?_=' + Math.floor(Date.now() / 300000))\n    .then(function(r) { return r.text(); })\n    .then(render)\n    .catch(function(e) {\n      wrap.innerHTML = '<div style=\"color:#f88;padding:20px\">Failed to load Day 2 outlook: ' + e + '<br><a href=\"https://www.spc.noaa.gov/products/outlook/day2otlk.html\" target=\"_blank\" style=\"color:#6bf\">Open on SPC</a></div>';\n    });\n})();\n</script>",
