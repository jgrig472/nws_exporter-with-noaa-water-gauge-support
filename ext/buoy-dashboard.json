      "panel-8": {
        "kind": "Panel",
        "spec": {
          "id": 8,
          "title": "Wind Speed & Direction Distribution",
          "description": "Wind rose showing the joint distribution of wind speed and direction over the selected time range. Requires the community Operato Windrose panel plugin (operato-windrose-panel), which requires fields literally named wind_speed and wind_direction in a single frame. Grafana's rename transforms only change display names, not the underlying field name, so the two queries are joined on time and then run through 'Add field from calculation' (reduceRow, single included field) to produce genuinely renamed wind_speed/wind_direction fields.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": { "name": "PBFA97CFB590B2093" },
                      "spec": {
                        "expr": "nws_buoy_wind_speed_mps{buoy_name=\"$buoy\"}"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": { "name": "PBFA97CFB590B2093" },
                      "spec": {
                        "expr": "nws_buoy_wind_direction_degrees{buoy_name=\"$buoy\"}"
                      }
                    },
                    "refId": "B",
                    "hidden": false
                  }
                }
              ],
              "transformations": [
                {
                  "kind": "joinByField",
                  "spec": {
                    "id": "joinByField",
                    "options": { "byField": "Time", "mode": "outer" }
                  }
                },
                {
                  "kind": "calculateField",
                  "spec": {
                    "id": "calculateField",
                    "options": {
                      "mode": "reduceRow",
                      "reduce": { "reducer": "lastNotNull", "include": ["nws_buoy_wind_speed_mps"] },
                      "alias": "wind_speed",
                      "replaceFields": false
                    }
                  }
                },
                {
                  "kind": "calculateField",
                  "spec": {
                    "id": "calculateField",
                    "options": {
                      "mode": "reduceRow",
                      "reduce": { "reducer": "lastNotNull", "include": ["nws_buoy_wind_direction_degrees"] },
                      "alias": "wind_direction",
                      "replaceFields": false
                    }
                  }
                }
              ],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "operato-windrose-panel",
            "version": "1.2.0",
            "spec": {
              "options": {},
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              }
            }
          }
        }
      },
